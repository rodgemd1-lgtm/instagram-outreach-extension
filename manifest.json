{
  "manifest_version": 3,
  "name": "Instagram Outreach Automation",
  "version": "1.0.0",
  "description": "Automate Instagram DM outreach campaigns with lead scraping, personalization, and analytics.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
